<div class="card">
    <div class="card-body">
        <h2>Ajouter un média</h2>

        <form method="post" action="/admin.php?module=media&action=save" enctype="multipart/form-data">
            <div class="mb-3">
                <label>Fichier</label>
                <input type="file" name="file" class="form-control" required>
            </div>

            <button class="btn btn-primary">Uploader</button>
        </form>
    </div>
</div>
