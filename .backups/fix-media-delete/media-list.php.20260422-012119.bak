<div class="card">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h2 class="h5 mb-1">Médias</h2>
            <div class="text-muted">Bibliothèque de fichiers</div>
        </div>
        <a class="btn btn-primary" href="/admin.php?module=media&action=create">Ajouter un média</a>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <?php if (empty($mediaItems)): ?>
            <div class="text-muted">Aucun média.</div>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Fichier</th>
                            <th>Type MIME</th>
                            <th>Aperçu</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($mediaItems as $item): ?>
                        <tr>
                            <td><?= (int)$item['id'] ?></td>
                            <td><?= e($item['title'] ?? '') ?></td>
                            <td><code><?= e($item['filename'] ?? '') ?></code></td>
                            <td><?= e($item['mime_type'] ?? '') ?></td>
                            <td>
                                <?php if (!empty($item['path']) && str_starts_with((string)($item['mime_type'] ?? ''), 'image/')): ?>
                                    <img src="<?= e($item['path']) ?>" alt="" style="max-width:80px; max-height:80px; object-fit:cover; border-radius:8px;">
                                <?php else: ?>
                                    <span class="text-muted">Aperçu indisponible</span>
                                <?php endif; ?>
                            </td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a class="btn btn-sm btn-outline-secondary" href="/admin.php?module=media&action=create">Modifier</a>
                                <a class="btn btn-sm btn-outline-danger" href="/admin.php?module=media&action=create" onclick="return confirm('Supprimer ce média ?')">Supprimer</a>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
    </div>
</div>
