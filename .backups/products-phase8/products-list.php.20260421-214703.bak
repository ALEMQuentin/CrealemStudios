<div class="card mt-4">
    <div class="card-body">
        <form method="get" action="/admin.php" class="row">
            <input type="hidden" name="module" value="products">

            <div class="col-md-4">
                <label class="form-label">Recherche</label>
                <input type="text" class="form-control" name="q" value="<?= e($_GET['q'] ?? '') ?>" placeholder="Nom, slug, SKU">
            </div>

            <div class="col-md-2">
                <label class="form-label">Statut</label>
                <select class="form-select" name="status_filter">
                    <option value="">Tous</option>
                    <option value="published" <?= (($_GET['status_filter'] ?? '') === 'published') ? 'selected' : '' ?>>Publié</option>
                    <option value="draft" <?= (($_GET['status_filter'] ?? '') === 'draft') ? 'selected' : '' ?>>Brouillon</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select class="form-select" name="type_filter">
                    <option value="">Tous</option>
                    <option value="simple" <?= (($_GET['type_filter'] ?? '') === 'simple') ? 'selected' : '' ?>>Simple</option>
                    <option value="variable" <?= (($_GET['type_filter'] ?? '') === 'variable') ? 'selected' : '' ?>>Variable</option>
                    <option value="grouped" <?= (($_GET['type_filter'] ?? '') === 'grouped') ? 'selected' : '' ?>>Groupé</option>
                    <option value="external" <?= (($_GET['type_filter'] ?? '') === 'external') ? 'selected' : '' ?>>Externe</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Stock</label>
                <select class="form-select" name="stock_filter">
                    <option value="">Tous</option>
                    <option value="instock" <?= (($_GET['stock_filter'] ?? '') === 'instock') ? 'selected' : '' ?>>En stock</option>
                    <option value="outofstock" <?= (($_GET['stock_filter'] ?? '') === 'outofstock') ? 'selected' : '' ?>>Rupture</option>
                    <option value="onbackorder" <?= (($_GET['stock_filter'] ?? '') === 'onbackorder') ? 'selected' : '' ?>>Commande</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-outline-secondary w-100" type="submit">Filtrer</button>
                <a class="btn btn-outline-secondary w-100" href="/admin.php?module=products">Reset</a>
            </div>
        </form>
    </div>
</div>

<form method="post" action="/admin.php?module=products&action=bulk" class="mt-4">
    <div class="card">
        <div class="card-body d-flex gap-2 flex-wrap align-items-end">
            <div>
                <label class="form-label">Action groupée</label>
                <select class="form-select" name="bulk_action" required>
                    <option value="">Choisir</option>
                    <option value="publish">Publier</option>
                    <option value="draft">Mettre en brouillon</option>
                    <option value="delete">Supprimer</option>
                </select>
            </div>
            <div>
                <button class="btn btn-outline-secondary" type="submit" onclick="return confirm('Appliquer cette action aux produits sélectionnés ?')">Appliquer</button>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-body">
            <?php if (empty($products)): ?>
                <div class="text-muted">Aucun produit.</div>
            <?php else: ?>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="width:40px;">
                                    <input type="checkbox" id="products-check-all">
                                </th>
                                <th>ID</th>
                                <th>Nom</th>
                                <th>SKU</th>
                                <th>Type</th>
                                <th>Prix</th>
                                <th>Stock</th>
                                <th>Visibilité</th>
                                <th>Galerie</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        <?php foreach ($products as $product): ?>
                            <tr>
                                <td>
                                    <input type="checkbox" name="product_ids[]" value="<?= (int)$product['id'] ?>" class="products-check-item">
                                </td>
                                <td><?= (int)$product['id'] ?></td>
                                <td><?= e($product['title'] ?? '') ?></td>
                                <td><code><?= e($product['sku'] ?? '') ?></code></td>
                                <td><?= e($product['product_type'] ?? 'simple') ?></td>
                                <td>
                                    <?php if (($product['sale_price'] ?? '') !== null && $product['sale_price'] !== ''): ?>
                                        <strong><?= e((string)$product['sale_price']) ?></strong>
                                        <br><span class="text-muted" style="text-decoration:line-through;"><?= e((string)($product['regular_price'] ?? '')) ?></span>
                                    <?php else: ?>
                                        <?= e((string)($product['regular_price'] ?? $product['price'] ?? '')) ?>
                                    <?php endif; ?>
                                </td>
                                <td>
                                    <?= e($product['stock_status'] ?? 'instock') ?>
                                    <?php if (($product['manage_stock'] ?? 0) == 1): ?>
                                        <br><span class="text-muted">Qté: <?= e((string)($product['stock_quantity'] ?? '')) ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= e($product['catalog_visibility'] ?? 'visible') ?></td>
                                <td><?= e((string)($product['gallery_count'] ?? '0')) ?></td>
                                <td><?= e($product['status'] ?? '') ?></td>
                                <td class="d-flex gap-2 flex-wrap">
                                    <a class="btn btn-sm btn-outline-secondary" href="/admin.php?module=products&action=edit&id=<?= (int)$product['id'] ?>">Modifier</a>
                                    <a class="btn btn-sm btn-outline-secondary" href="/admin.php?module=products&action=duplicate&id=<?= (int)$product['id'] ?>">Dupliquer</a>
                                    <a class="btn btn-sm btn-outline-secondary" href="/admin.php?module=products&action=variations&id=<?= (int)$product['id'] ?>">Variations</a>
                                    <a class="btn btn-sm btn-outline-danger" href="/admin.php?module=products&action=delete&id=<?= (int)$product['id'] ?>" onclick="return confirm('Supprimer ce produit ?')">Supprimer</a>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php endif; ?>
        </div>
    </div>
</form>

<script>
(function () {
    var checkAll = document.getElementById('products-check-all');
    if (!checkAll) return;

    checkAll.addEventListener('change', function () {
        document.querySelectorAll('.products-check-item').forEach(function (item) {
            item.checked = checkAll.checked;
        });
    });
})();
</script>
